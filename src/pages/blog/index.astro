---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf(),
);
---
<BaseLayout
  pagePath="/blog"
  title="Pro Tiling Blog | Tile Tips, Design Ideas, and Remodeling Advice"
  description="Get tile installation tips, bathroom remodel ideas, and expert advice from Sacramento tile contractors."
  canonical="https://www.protiling.com/blog"
  ogTitle="Pro Tiling Blog"
  ogDescription="Tile guides and design ideas from Sacramento tile specialists."
>
  <section class="page-hero">
    <div class="container">
      <div class="page-hero__content">
        <nav class="page-hero__breadcrumb" aria-label="Breadcrumb">
          <a href="/">Home</a><span>›</span><span>Blog</span>
        </nav>
        <h1>Tile Guides and Remodeling Insights</h1>
        <p>Practical advice from Sacramento tile professionals to help you plan your next project with confidence.</p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="services-grid">
        {posts.map((post) => (
          <article class="service-card">
            <h3>{post.data.title}</h3>
            <p>{post.data.description}</p>
            <p style="font-size:0.8rem;color:var(--mid-gray);margin-bottom:18px;">
              {post.data.publishDate.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}
            </p>
            <a class="service-card__link" href={`/blog/${post.id.replace(/\.md$/, "")}`}>Read Article</a>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

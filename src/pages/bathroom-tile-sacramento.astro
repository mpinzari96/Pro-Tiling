const schemaScripts = ["{\"@context\":\"https://schema.org\",\"@type\":\"Service\",\"name\":\"Bathroom Tile Sacramento\",\"provider\":{\"@type\":\"LocalBusiness\",\"name\":\"Pro Tiling\",\"telephone\":\"(916) 555-0100\"},\"areaServed\":{\"@type\":\"City\",\"name\":\"Sacramento\"},\"description\":\"Custom bathroom tile installation and remodeling in Sacramento including floor tile, wall tile, and shower surrounds.\",\"serviceType\":\"Bathroom Tile Installation\"}"];
const contentHtml = "<section class=\"page-hero\">\n      <div class=\"container\">\n        <div class=\"page-hero__content\">\n          <nav class=\"page-hero__breadcrumb\" aria-label=\"Breadcrumb\">\n            <a href=\"/\">Home</a><span>\u203a</span><span>Bathroom Tile Sacramento</span>\n          </nav>\n          <h1>Bathroom Tile Remodeling in Sacramento, CA</h1>\n          <p>Custom bathroom tile installations that turn ordinary bathrooms into spaces worth showing off. Expert craftsmanship, clean execution, and results that hold up for years.</p>\n          <div class=\"page-hero__cta\">\n            <a href=\"/contact\" class=\"btn btn--primary\">Get a Free Estimate</a>\n            <a href=\"tel:9165550100\" class=\"btn btn--outline\">Call (916) 555-0100</a>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <section class=\"section\">\n      <div class=\"container\">\n        <div class=\"service-content\">\n          <div class=\"content-body\">\n            <span class=\"section-label\">Bathroom Tile Experts</span>\n            <h2>Transform Your Bathroom with Custom Tile</h2>\n            <p>The bathroom is one of the highest-impact rooms in your home \u2014 and tile is the material that makes or breaks it. Whether you're doing a full gut renovation or just replacing dated floor tile, Pro Tiling brings the same level of precision and attention to detail to every Sacramento bathroom project we take on.</p>\n            <p>We've remodeled bathrooms throughout Sacramento, Elk Grove, Roseville, and Folsom \u2014 from compact guest baths to sprawling master suites with radiant heat, custom shower niches, and book-matched stone walls. We know what it takes to get the details right.</p>\n\n            <img class=\"content-img\" src=\"https://images.unsplash.com/photo-1552321554-5fefe8c9ef14?w=900&q=80\" alt=\"Custom bathroom tile remodel in Sacramento \u2014 floor and wall tile installation\" loading=\"lazy\" width=\"900\" height=\"506\" />\n\n            <h2>Bathroom Tile Services We Provide</h2>\n\n            <h3>Bathroom Floor Tile</h3>\n            <p>A new bathroom floor completely changes the feel of the space. We install everything from classic penny round mosaic in a master bath to large 24x48 porcelain in a modern primary suite. Heated floor systems, linear drains, and waterproofed wet room designs are all within our wheelhouse.</p>\n\n            <h3>Bathroom Wall Tile</h3>\n            <p>Wall tile in a bathroom can go floor-to-ceiling or run as wainscoting \u2014 either way we plan the layout to ensure balanced cuts, level courses, and grout lines that actually align from wall to wall. A lot of DIY and rushed contractor work fails here. Ours doesn't.</p>\n\n            <h3>Tub Surrounds</h3>\n            <p>A properly waterproofed and tiled tub surround extends the life of the installation and eliminates water intrusion issues. We install shower-grade waterproofing membranes on all wet areas \u2014 not just cement board \u2014 before any tile goes up.</p>\n\n            <h3>Accent & Decorative Tile</h3>\n            <p>Listello borders, mosaic feature strips, niche tile, and decorative field tile transitions are where a bathroom goes from nice to exceptional. We work closely with you during planning to incorporate accent details that pull the room together.</p>\n\n            <h2>What to Expect During Your Bathroom Tile Remodel</h2>\n            <p>We know you're letting people into your home. We keep the work area contained, protect surrounding surfaces, and clean up every day before we leave. Here's how a typical bathroom tile remodel unfolds with Pro Tiling:</p>\n            <ul>\n              <li>Initial consultation and free estimate (usually same week)</li>\n              <li>Material and tile selection guidance if needed</li>\n              <li>Demo of existing tile and surface assessment</li>\n              <li>Waterproofing installation on all wet areas</li>\n              <li>Tile setting \u2014 floor first, walls second for best results</li>\n              <li>Curing time, then grout and sealant</li>\n              <li>Final cleanup and walkthrough \u2014 you approve before we leave</li>\n            </ul>\n\n            <h2>Popular Bathroom Tile Styles in Sacramento</h2>\n            <p>Sacramento homeowners are increasingly moving toward large-format porcelain for primary bathrooms \u2014 it reads as more luxurious and reduces grout maintenance. For secondary bathrooms and powder rooms, subway tile in a variety of finishes and patterns remains the most popular choice. We'll show you what's trending and what actually works for your space during your estimate.</p>\n\n            <div class=\"faq\">\n              <h2 style=\"margin-bottom:8px;\">Bathroom Tile Questions</h2>\n              <div class=\"faq-item\">\n                <button class=\"faq-item__question\">How long does a full bathroom tile remodel take? <span class=\"faq-item__icon\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><line x1=\"12\" y1=\"5\" x2=\"12\" y2=\"19\"/><line x1=\"5\" y1=\"12\" x2=\"19\" y2=\"12\"/></svg></span></button>\n                <div class=\"faq-item__answer\"><p>A full bathroom tile remodel \u2014 demo, prep, floor, walls, and grouting \u2014 typically takes 4\u20137 business days. A floor-only replacement can be done in 2\u20133 days. We'll give you a specific timeline for your project during the estimate.</p></div>\n              </div>\n              <div class=\"faq-item\">\n                <button class=\"faq-item__question\">Do you waterproof behind shower and tub areas? <span class=\"faq-item__icon\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><line x1=\"12\" y1=\"5\" x2=\"12\" y2=\"19\"/><line x1=\"5\" y1=\"12\" x2=\"19\" y2=\"12\"/></svg></span></button>\n                <div class=\"faq-item__answer\"><p>Always. This is non-negotiable for us. We install a full waterproofing membrane \u2014 not just cement board \u2014 on all wet walls and floors before any tile is set. This is what prevents water intrusion and mold problems years down the line.</p></div>\n              </div>\n            </div>\n          </div>\n\n          <aside class=\"service-sidebar\">\n            <div class=\"sidebar-card\">\n              <h3>Get a Free Estimate</h3>\n              <p style=\"font-size:0.875rem;margin-bottom:18px;\">We respond same day. No hard sell \u2014 just an honest assessment.</p>\n              <a href=\"/contact\" class=\"btn btn--primary\" style=\"width:100%;justify-content:center;\">Request a Quote</a>\n              <a href=\"tel:9165550100\" class=\"btn btn--outline-dark\" style=\"width:100%;justify-content:center;margin-top:10px;\">Call (916) 555-0100</a>\n            </div>\n            <div class=\"sidebar-card\">\n              <h3>Bathroom Tile Includes</h3>\n              <ul>\n                <li><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><polyline points=\"20 6 9 17 4 12\"/></svg>Full waterproofing</li>\n                <li><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><polyline points=\"20 6 9 17 4 12\"/></svg>Floor & wall tile</li>\n                <li><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><polyline points=\"20 6 9 17 4 12\"/></svg>Tub surrounds</li>\n                <li><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><polyline points=\"20 6 9 17 4 12\"/></svg>Custom niches & accents</li>\n                <li><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><polyline points=\"20 6 9 17 4 12\"/></svg>Grout & sealing</li>\n              </ul>\n            </div>\n            <div class=\"sidebar-card\">\n              <h3>Related Services</h3>\n              <div class=\"sidebar-links\">\n                <a href=\"/shower-tile-installation-sacramento\">\u2192 Shower Tile Installation</a>\n                <a href=\"/tile-installation-sacramento\">\u2192 General Tile Installation</a>\n                <a href=\"/backsplash-installation-sacramento\">\u2192 Kitchen Backsplash</a>\n              </div>\n            </div>\n          </aside>\n        </div>\n      </div>\n    </section>\n\n    <section class=\"cta-band\">\n      <div class=\"container\">\n        <div class=\"cta-band__inner\">\n          <h2>Your dream bathroom is <em>one call away</em>.</h2>\n          <div class=\"cta-band__actions\">\n            <a href=\"tel:9165550100\" class=\"btn btn--primary\">(916) 555-0100</a>\n            <a href=\"/contact\" class=\"btn btn--outline\">Free Estimate</a>\n          </div>\n        </div>\n      </div>\n    </section>";

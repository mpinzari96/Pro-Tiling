---
import BaseLayout from "../layouts/BaseLayout.astro";
const pagePath = "/tile-installation-sacramento";
const title = "Tile Installation Sacramento | Pro Tiling Contractor";
const description = "";
const canonical = "";
const ogTitle = "";
const ogDescription = "";
const ogType = "";
const ogUrl = "";
const schemaScripts = ["{\n    \"@context\": \"https://schema.org\",\n    \"@type\": \"Service\",\n    \"name\": \"Tile Installation Sacramento\",\n    \"provider\": {\"@type\": \"LocalBusiness\", \"name\": \"Pro Tiling\", \"telephone\": \"(916) 555-0100\"},\n    \"areaServed\": {\"@type\": \"City\", \"name\": \"Sacramento\"},\n    \"description\": \"Professional tile installation services in Sacramento including floor tile, wall tile, custom patterns and large-format tile installation.\",\n    \"serviceType\": \"Tile Installation\"\n  }", "{\n    \"@context\": \"https://schema.org\",\n    \"@type\": \"FAQPage\",\n    \"mainEntity\": [\n      {\"@type\":\"Question\",\"name\":\"What types of tile do you install in Sacramento?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"We install all tile types including porcelain, ceramic, natural stone (travertine, marble, slate), glass, mosaic, encaustic cement tile, and large-format slabs up to 60x120.\"}},\n      {\"@type\":\"Question\",\"name\":\"Do you handle floor prep and underlayment?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes. Proper surface prep is the most important part of any tile job. We handle leveling, backer board installation, waterproofing membranes, and any other prep work required before laying a single tile.\"}}\n    ]\n  }"];
const contentHtml = "<section class=\"page-hero\">\n      <div class=\"container\">\n        <div class=\"page-hero__content\">\n          <nav class=\"page-hero__breadcrumb\" aria-label=\"Breadcrumb\">\n            <a href=\"/\">Home</a>\n            <span>\u203a</span>\n            <span>Tile Installation Sacramento</span>\n          </nav>\n          <h1>Tile Installation in Sacramento, CA</h1>\n          <p>Expert installation for every tile type and every room \u2014 done right the first time. Serving Sacramento, Elk Grove, Roseville, Folsom, and the surrounding region.</p>\n          <div class=\"page-hero__cta\">\n            <a href=\"/contact\" class=\"btn btn--primary\">Get a Free Estimate</a>\n            <a href=\"tel:9165550100\" class=\"btn btn--outline\">Call (916) 555-0100</a>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <section class=\"section\">\n      <div class=\"container\">\n        <div class=\"service-content\">\n          <div class=\"content-body\">\n            <span class=\"section-label\">Sacramento Tile Contractor</span>\n            <h2>Professional Tile Installation You Can Count On</h2>\n            <p>When you hire Pro Tiling for your Sacramento tile installation project, you're getting more than someone who lays tile \u2014 you're getting a decade of hands-on experience, the right tools for every job, and a crew that treats your home with respect from day one to job completion.</p>\n            <p>We've installed tile in hundreds of Sacramento-area homes, from straightforward ceramic floor replacements in Rancho Cordova to elaborate large-format porcelain wall systems in custom homes in Folsom and El Dorado Hills. No project is too simple or too complex.</p>\n\n            <img class=\"content-img\" src=\"https://images.unsplash.com/photo-1584622650111-993a426fbf0a?w=900&q=80\" alt=\"Professional tile installation Sacramento \u2014 large format floor tile being set\" loading=\"lazy\" width=\"900\" height=\"506\" />\n\n            <h2>Types of Tile Installation We Offer</h2>\n            <h3>Floor Tile Installation</h3>\n            <p>Whether it's a kitchen, bathroom, entryway, or living room, we install tile floors that look flawless and last for decades. We work with all formats \u2014 from classic 12x12 ceramic to 48x96 large-format porcelain slabs \u2014 and every layout pattern including straight set, offset/brick, diagonal, herringbone, and custom designs.</p>\n            <p>Proper floor prep is non-negotiable for us. We check for deflection, install cement backer board or Schluter Ditra where needed, and use premium thin-set mortars appropriate for the tile type. This is why our floors don't crack, pop, or show lippage after a year.</p>\n\n            <h3>Wall Tile Installation</h3>\n            <p>Wall tile in Sacramento homes runs the gamut from classic subway tile in bathrooms to full-height natural stone in open-concept kitchens. We handle all of it \u2014 ensuring level, plumb surfaces, consistent grout joints, and proper waterproofing behind wet areas.</p>\n\n            <h3>Large-Format Tile</h3>\n            <p>Large-format tile (anything over 15\" on the short side) requires specialized skills, equipment, and mortars. We're experienced with slabs up to 60x120, including proper back-buttering, lippage management, and the additional surface prep these tiles demand.</p>\n\n            <h3>Custom Pattern Tile Work</h3>\n            <p>Herringbone, Versailles, windmill, pinwheel, basketweave \u2014 custom layouts take precision layout planning and patience. We start every custom pattern with a dry layout to dial in the look before any mortar hits the floor. Sacramento homeowners hire us specifically for this kind of work when other contractors say it's too complicated.</p>\n\n            <h2>Our Installation Process</h2>\n            <p>Every tile installation with Pro Tiling follows the same disciplined process:</p>\n            <ul>\n              <li>Free on-site estimate and project assessment</li>\n              <li>Surface inspection \u2014 checking for level, structural integrity, and moisture</li>\n              <li>Demo and debris removal (if applicable)</li>\n              <li>Surface prep: backer board, waterproofing membranes, leveling compounds</li>\n              <li>Layout planning \u2014 always a dry run before mortar</li>\n              <li>Tile setting with appropriate mortar and trowel technique</li>\n              <li>Curing period before grouting</li>\n              <li>Grout installation and sealing</li>\n              <li>Final cleanup and walkthrough</li>\n            </ul>\n\n            <h2>Tile Types We Work With</h2>\n            <ul>\n              <li>Porcelain tile (rectified and non-rectified)</li>\n              <li>Ceramic tile</li>\n              <li>Natural stone \u2014 travertine, marble, slate, limestone</li>\n              <li>Glass tile and glass mosaic</li>\n              <li>Encaustic and cement tile</li>\n              <li>Large-format porcelain slabs</li>\n              <li>Subway tile in all sizes</li>\n              <li>Mosaic and penny tile</li>\n            </ul>\n\n            <h2>Serving Sacramento and Beyond</h2>\n            <p>We provide tile installation throughout the Sacramento metro area including Elk Grove, Roseville, Folsom, Natomas, Rancho Cordova, Citrus Heights, and Rocklin. If you're not sure whether we cover your area, just call \u2014 we're flexible on service radius for the right project.</p>\n\n            <div class=\"faq\" role=\"list\">\n              <h2 style=\"margin-bottom:8px;\">Common Questions</h2>\n              <div class=\"faq-item\">\n                <button class=\"faq-item__question\">What types of tile do you install in Sacramento? <span class=\"faq-item__icon\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><line x1=\"12\" y1=\"5\" x2=\"12\" y2=\"19\"/><line x1=\"5\" y1=\"12\" x2=\"19\" y2=\"12\"/></svg></span></button>\n                <div class=\"faq-item__answer\"><p>We install all tile types: porcelain, ceramic, natural stone (travertine, marble, slate), glass, mosaic, encaustic cement tile, and large-format slabs up to 60x120. If it's tile, we can set it.</p></div>\n              </div>\n              <div class=\"faq-item\">\n                <button class=\"faq-item__question\">Do you handle floor prep and underlayment? <span class=\"faq-item__icon\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><line x1=\"12\" y1=\"5\" x2=\"12\" y2=\"19\"/><line x1=\"5\" y1=\"12\" x2=\"19\" y2=\"12\"/></svg></span></button>\n                <div class=\"faq-item__answer\"><p>Yes. Proper surface prep is the most important part of any tile job. We handle leveling, backer board installation, waterproofing membranes, and all other prep work before laying a single tile.</p></div>\n              </div>\n            </div>\n          </div>\n\n          <aside class=\"service-sidebar\">\n            <div class=\"sidebar-card\">\n              <h3>Get a Free Estimate</h3>\n              <p style=\"font-size:0.875rem;margin-bottom:18px;\">Tell us about your project and we'll get back to you the same day.</p>\n              <a href=\"/contact\" class=\"btn btn--primary\" style=\"width:100%;justify-content:center;\">Request a Quote</a>\n              <a href=\"tel:9165550100\" class=\"btn btn--outline-dark\" style=\"width:100%;justify-content:center;margin-top:10px;\">Call (916) 555-0100</a>\n            </div>\n            <div class=\"sidebar-card\">\n              <h3>Why Choose Pro Tiling</h3>\n              <ul>\n                <li><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><polyline points=\"20 6 9 17 4 12\"/></svg>10+ years experience</li>\n                <li><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><polyline points=\"20 6 9 17 4 12\"/></svg>CA Licensed & insured</li>\n                <li><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><polyline points=\"20 6 9 17 4 12\"/></svg>All tile types & formats</li>\n                <li><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><polyline points=\"20 6 9 17 4 12\"/></svg>Full surface prep included</li>\n                <li><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><polyline points=\"20 6 9 17 4 12\"/></svg>Written estimates</li>\n                <li><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><polyline points=\"20 6 9 17 4 12\"/></svg>5-star rated</li>\n              </ul>\n            </div>\n            <div class=\"sidebar-card\">\n              <h3>Other Services</h3>\n              <div class=\"sidebar-links\">\n                <a href=\"/bathroom-tile-sacramento\">\u2192 Bathroom Tile Remodeling</a>\n                <a href=\"/shower-tile-installation-sacramento\">\u2192 Shower Tile Installation</a>\n                <a href=\"/backsplash-installation-sacramento\">\u2192 Kitchen Backsplash</a>\n              </div>\n            </div>\n          </aside>\n        </div>\n      </div>\n    </section>\n\n    <section class=\"cta-band\">\n      <div class=\"container\">\n        <div class=\"cta-band__inner\">\n          <h2>Need tile installed in <em>Sacramento</em>? Let's talk.</h2>\n          <div class=\"cta-band__actions\">\n            <a href=\"tel:9165550100\" class=\"btn btn--primary\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81\"/></svg>(916) 555-0100</a>\n            <a href=\"/contact\" class=\"btn btn--outline\">Get a Free Quote</a>\n          </div>\n        </div>\n      </div>\n    </section>";
---

<BaseLayout
  pagePath={pagePath}
  title={title}
  description={description}
  canonical={canonical}
  ogTitle={ogTitle}

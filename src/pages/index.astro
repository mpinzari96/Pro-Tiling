const schemaScripts = ["{\n    \"@context\": \"https://schema.org\",\n    \"@type\": \"HomeAndConstructionBusiness\",\n    \"name\": \"Pro Tiling\",\n    \"url\": \"https://www.protiling.com\",\n    \"telephone\": \"(916) 555-0100\",\n    \"email\": \"info@protiling.com\",\n    \"description\": \"Pro Tiling is Sacramento's premier tile contractor specializing in custom tile installations, bathroom remodels, shower tile, kitchen backsplashes, and tile flooring.\",\n    \"address\": {\n      \"@type\": \"PostalAddress\",\n      \"streetAddress\": \"123 Main Street\",\n      \"addressLocality\": \"Sacramento\",\n      \"addressRegion\": \"CA\",\n      \"postalCode\": \"95814\",\n      \"addressCountry\": \"US\"\n    },\n    \"geo\": {\n      \"@type\": \"GeoCoordinates\",\n      \"latitude\": 38.5816,\n      \"longitude\": -121.4944\n    },\n    \"areaServed\": [\n      {\"@type\": \"City\", \"name\": \"Sacramento\"},\n      {\"@type\": \"City\", \"name\": \"Elk Grove\"},\n      {\"@type\": \"City\", \"name\": \"Roseville\"},\n      {\"@type\": \"City\", \"name\": \"Folsom\"},\n      {\"@type\": \"City\", \"name\": \"Natomas\"},\n      {\"@type\": \"City\", \"name\": \"Rancho Cordova\"},\n      {\"@type\": \"City\", \"name\": \"Citrus Heights\"},\n      {\"@type\": \"City\", \"name\": \"Rocklin\"}\n    ],\n    \"openingHoursSpecification\": [\n      {\"@type\": \"OpeningHoursSpecification\", \"dayOfWeek\": [\"Monday\",\"Tuesday\",\"Wednesday\",\"Thursday\",\"Friday\"], \"opens\": \"07:00\", \"closes\": \"18:00\"},\n      {\"@type\": \"OpeningHoursSpecification\", \"dayOfWeek\": \"Saturday\", \"opens\": \"08:00\", \"closes\": \"14:00\"}\n    ],\n    \"sameAs\": [\"https://www.instagram.com/protiling\"],\n    \"aggregateRating\": {\n      \"@type\": \"AggregateRating\",\n      \"ratingValue\": \"5\",\n      \"reviewCount\": \"47\"\n    }\n  }", "{\n    \"@context\": \"https://schema.org\",\n    \"@type\": \"FAQPage\",\n    \"mainEntity\": [\n      {\n        \"@type\": \"Question\",\n        \"name\": \"How much does tile installation cost in Sacramento?\",\n        \"acceptedAnswer\": {\n          \"@type\": \"Answer\",\n          \"text\": \"Tile installation in Sacramento typically ranges from $8\u2013$25 per square foot depending on tile type, layout complexity, and surface prep required. We provide free, detailed estimates for every project.\"\n        }\n      },\n      {\n        \"@type\": \"Question\",\n        \"name\": \"How long does a bathroom tile remodel take?\",\n        \"acceptedAnswer\": {\n          \"@type\": \"Answer\",\n          \"text\": \"Most bathroom tile remodels in the Sacramento area take 3\u20137 business days, depending on the scope of work, tile selection, and demolition required. We'll give you a clear timeline before we start.\"\n        }\n      },\n      {\n        \"@type\": \"Question\",\n        \"name\": \"Are you licensed and insured in California?\",\n        \"acceptedAnswer\": {\n          \"@type\": \"Answer\",\n          \"text\": \"Yes. Pro Tiling is fully licensed and insured in California. We carry general liability insurance and workers' compensation on every job.\"\n        }\n      },\n      {\n        \"@type\": \"Question\",\n        \"name\": \"What areas do you serve around Sacramento?\",\n        \"acceptedAnswer\": {\n          \"@type\": \"Answer\",\n          \"text\": \"We serve the greater Sacramento area including Elk Grove, Roseville, Folsom, Natomas, Rancho Cordova, Citrus Heights, Rocklin, and surrounding communities.\"\n        }\n      }\n    ]\n  }"];
const contentHtml = "<!-- ======= HERO ======= -->\n    <section class=\"hero\" aria-label=\"Hero\">\n      <div class=\"hero__bg\" role=\"presentation\"></div>\n      <div class=\"hero__bg-pattern\" role=\"presentation\"></div>\n      <div class=\"container\">\n        <div class=\"hero__content\">\n          <span class=\"hero__eyebrow\">Sacramento's Tile Experts \u2014 10+ Years</span>\n          <h1>\n            Precision Tile Work,<br>\n            <em>Built to Last</em>\n          </h1>\n          <p class=\"hero__sub\">\n            From custom shower surrounds to large-format floor tile, Pro Tiling delivers\n            craftsmanship that transforms Sacramento homes. Licensed, insured, and trusted\n            by homeowners across the greater Sacramento area.\n          </p>\n          <div class=\"hero__actions\">\n            <a href=\"/contact\" class=\"btn btn--primary\">\n              <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z\"/></svg>\n              Get a Free Estimate\n            </a>\n            <a href=\"tel:9165550100\" class=\"btn btn--outline\">\n              <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81 19.79 19.79 0 01.01 1.18 2 2 0 012 .01h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 14.92z\"/></svg>\n              Call Now\n            </a>\n          </div>\n          <div class=\"hero__trust\" role=\"list\" aria-label=\"Trust indicators\">\n            <div class=\"hero__trust-item\" role=\"listitem\">\n              <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><polyline points=\"20 6 9 17 4 12\"/></svg>\n              Licensed & Insured\n            </div>\n            <div class=\"hero__trust-item\" role=\"listitem\">\n              <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><polyline points=\"20 6 9 17 4 12\"/></svg>\n              10+ Years Experience\n            </div>\n            <div class=\"hero__trust-item\" role=\"listitem\">\n              <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><polyline points=\"20 6 9 17 4 12\"/></svg>\n              Free Estimates\n            </div>\n            <div class=\"hero__trust-item\" role=\"listitem\">\n              <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><polyline points=\"20 6 9 17 4 12\"/></svg>\n              5-Star Rated\n            </div>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <!-- ======= STATS STRIP ======= -->\n    <div class=\"stats-strip\" aria-label=\"Key stats\">\n      <div class=\"container\">\n        <div class=\"stats-strip__grid\">\n          <div class=\"stat-item\">\n            <div class=\"stat-item__number\">10+</div>\n            <div class=\"stat-item__label\">Years in Business</div>\n          </div>\n          <div class=\"stat-item\">\n            <div class=\"stat-item__number\">500+</div>\n            <div class=\"stat-item__label\">Projects Completed</div>\n          </div>\n          <div class=\"stat-item\">\n            <div class=\"stat-item__number\">5.0</div>\n            <div class=\"stat-item__label\">Average Rating</div>\n          </div>\n          <div class=\"stat-item\">\n            <div class=\"stat-item__number\">8+</div>\n            <div class=\"stat-item__label\">Cities Served</div>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    <!-- ======= SERVICES ======= -->\n    <section class=\"section\" aria-labelledby=\"services-heading\">\n      <div class=\"container\">\n        <div class=\"text-center animate-on-scroll\">\n          <span class=\"section-label\">What We Do</span>\n          <h2 id=\"services-heading\">Tile Services for Every Room</h2>\n          <p style=\"max-width:520px;margin:14px auto 0;\">From concept to grouted finish, we handle every aspect of your tile project \u2014 bringing precision and craftsmanship to homes across Sacramento.</p>\n        </div>\n        <div class=\"services-grid\">\n          <article class=\"service-card animate-on-scroll\">\n            <div class=\"service-card__icon\">\n              <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.8\"><rect x=\"3\" y=\"3\" width=\"7\" height=\"7\"/><rect x=\"14\" y=\"3\" width=\"7\" height=\"7\"/><rect x=\"14\" y=\"14\" width=\"7\" height=\"7\"/><rect x=\"3\" y=\"14\" width=\"7\" height=\"7\"/></svg>\n            </div>\n            <h3>Tile Installation</h3>\n            <p>Full-service tile installation for floors, walls, and feature areas throughout your home. We work with all tile types and handle surface prep, layout, setting, and grouting.</p>\n            <a href=\"/tile-installation-sacramento\" class=\"service-card__link\">\n              Learn More\n              <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M5 12h14M12 5l7 7-7 7\"/></svg>\n            </a>\n          </article>\n          <article class=\"service-card animate-on-scroll\">\n            <div class=\"service-card__icon\">\n              <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.8\"><path d=\"M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z\"/><polyline points=\"9 22 9 12 15 12 15 22\"/></svg>\n            </div>\n            <h3>Bathroom Tile Remodeling</h3>\n            <p>Transform your bathroom with custom tile that reflects your style. We specialize in complete bathroom tile renovations \u2014 floors, walls, and accent details \u2014 done right the first time.</p>\n            <a href=\"/bathroom-tile-sacramento\" class=\"service-card__link\">\n              Learn More\n              <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M5 12h14M12 5l7 7-7 7\"/></svg>\n            </a>\n          </article>\n          <article class=\"service-card animate-on-scroll\">\n            <div class=\"service-card__icon\">\n              <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.8\"><path d=\"M4 4h16v16H4z\"/><path d=\"M4 9h16M4 14h16M9 4v16M14 4v16\"/></svg>\n            </div>\n            <h3>Shower Tile Installation</h3>\n            <p>Custom shower tile installations built for beauty and longevity. From zero-entry walk-ins to tiled tub surrounds, we waterproof and tile to the highest standards.</p>\n            <a href=\"/shower-tile-installation-sacramento\" class=\"service-card__link\">\n              Learn More\n              <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M5 12h14M12 5l7 7-7 7\"/></svg>\n            </a>\n          </article>\n          <article class=\"service-card animate-on-scroll\">\n            <div class=\"service-card__icon\">\n              <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.8\"><path d=\"M12 2L2 7l10 5 10-5-10-5z\"/><path d=\"M2 17l10 5 10-5\"/><path d=\"M2 12l10 5 10-5\"/></svg>\n            </div>\n            <h3>Kitchen Backsplash</h3>\n            <p>Elevate your kitchen with a custom tile backsplash that ties the whole space together. Subway tile, mosaic patterns, full-height slabs \u2014 we install it all with clean, precise lines.</p>\n            <a href=\"/backsplash-installation-sacramento\" class=\"service-card__link\">\n              Learn More\n              <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M5 12h14M12 5l7 7-7 7\"/></svg>\n            </a>\n          </article>\n          <article class=\"service-card animate-on-scroll\">\n            <div class=\"service-card__icon\">\n              <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.8\"><rect x=\"2\" y=\"2\" width=\"20\" height=\"20\" rx=\"2\"/><path d=\"M2 12h20M12 2v20\"/></svg>\n            </div>\n            <h3>Tile Flooring</h3>\n            <p>Durable, beautiful tile floors for kitchens, bathrooms, entryways, and living spaces. We work with porcelain, ceramic, travertine, and large-format tile in any layout pattern.</p>\n            <a href=\"/tile-installation-sacramento\" class=\"service-card__link\">\n              Learn More\n              <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M5 12h14M12 5l7 7-7 7\"/></svg>\n            </a>\n          </article>\n          <article class=\"service-card animate-on-scroll\">\n            <div class=\"service-card__icon\">\n              <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.8\"><polygon points=\"12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2\"/></svg>\n            </div>\n            <h3>Custom Tile Work</h3>\n            <p>Unique feature walls, custom patterns, herringbone layouts, handmade tile \u2014 if you can dream it, we can install it. We bring complex, high-end custom tile concepts to life.</p>\n            <a href=\"/tile-installation-sacramento\" class=\"service-card__link\">\n              Learn More\n              <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M5 12h14M12 5l7 7-7 7\"/></svg>\n            </a>\n          </article>\n        </div>\n      </div>\n    </section>\n\n    <!-- ======= WHY US ======= -->\n    <section class=\"section section--gray\" aria-labelledby=\"why-heading\">\n      <div class=\"container\">\n        <div class=\"why-grid\">\n          <div class=\"why-grid__image animate-on-scroll\">\n            <img\n              class=\"why-grid__img-main\"\n              src=\"https://images.unsplash.com/photo-1571902943202-507ec2618e8f?w=800&q=80\"\n              alt=\"Pro Tiling craftsman installing large format tile in a Sacramento bathroom\"\n              width=\"560\"\n              height=\"700\"\n              loading=\"lazy\"\n            />\n            <div class=\"why-grid__img-badge\">\n              <strong>10+</strong>\n              <span>Years of<br>Excellence</span>\n            </div>\n          </div>\n          <div class=\"animate-on-scroll\">\n            <span class=\"section-label\">Why Pro Tiling</span>\n            <h2 id=\"why-heading\">Sacramento's Choice for High-End Tile Work</h2>\n            <p class=\"lead\" style=\"margin-top:16px;\">We're not the right fit for every job \u2014 and that's intentional. We focus on projects where craftsmanship actually matters, and we build every installation to outlast the house it's in.</p>\n            <div class=\"why-features\">\n              <div class=\"why-feature\">\n                <div class=\"why-feature__icon\">\n                  <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z\"/></svg>\n                </div>\n                <div>\n                  <h4>Licensed & Fully Insured</h4>\n                  <p>California-licensed tile contractor carrying full general liability and workers' comp. You're protected on every job.</p>\n                </div>\n              </div>\n              <div class=\"why-feature\">\n                <div class=\"why-feature__icon\">\n                  <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><circle cx=\"12\" cy=\"12\" r=\"10\"/><polyline points=\"12 6 12 12 16 14\"/></svg>\n                </div>\n                <div>\n                  <h4>On Time, Every Time</h4>\n                  <p>We show up when we say we will and finish when we say we'll finish. No half-done bathrooms sitting around for weeks.</p>\n                </div>\n              </div>\n              <div class=\"why-feature\">\n                <div class=\"why-feature__icon\">\n                  <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M14.5 10c-.83 0-1.5-.67-1.5-1.5v-5c0-.83.67-1.5 1.5-1.5s1.5.67 1.5 1.5v5c0 .83-.67 1.5-1.5 1.5z\"/><path d=\"M20.5 10H19V8.5c0-.83.67-1.5 1.5-1.5s1.5.67 1.5 1.5-.67 1.5-1.5 1.5z\"/><path d=\"M9.5 14c.83 0 1.5.67 1.5 1.5v5c0 .83-.67 1.5-1.5 1.5S8 21.33 8 20.5v-5c0-.83.67-1.5 1.5-1.5z\"/><path d=\"M3.5 14H5v1.5c0 .83-.67 1.5-1.5 1.5S2 16.33 2 15.5 2.67 14 3.5 14z\"/><path d=\"M14 14.5c0-.83.67-1.5 1.5-1.5h5c.83 0 1.5.67 1.5 1.5s-.67 1.5-1.5 1.5h-5c-.83 0-1.5-.67-1.5-1.5z\"/><path d=\"M15.5 19H14v1.5c0 .83.67 1.5 1.5 1.5s1.5-.67 1.5-1.5-.67-1.5-1.5-1.5z\"/><path d=\"M10 9.5C10 8.67 9.33 8 8.5 8h-5C2.67 8 2 8.67 2 9.5S2.67 11 3.5 11h5c.83 0 1.5-.67 1.5-1.5z\"/><path d=\"M8.5 5H10V3.5C10 2.67 9.33 2 8.5 2S7 2.67 7 3.5 7.67 5 8.5 5z\"/></svg>\n                </div>\n                <div>\n                  <h4>Tile-Only Specialization</h4>\n                  <p>We do one thing and we do it exceptionally well. No general contractors juggling 12 trades \u2014 just focused, expert tile work on every project.</p>\n                </div>\n              </div>\n              <div class=\"why-feature\">\n                <div class=\"why-feature__icon\">\n                  <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z\"/><circle cx=\"12\" cy=\"10\" r=\"3\"/></svg>\n                </div>\n                <div>\n                  <h4>Sacramento Local</h4>\n                  <p>Based right here in Sacramento \u2014 not a franchise, not a call center. When you call, you talk to us directly.</p>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <!-- ======= PORTFOLIO ======= -->\n    <section class=\"section\" aria-labelledby=\"portfolio-heading\">\n      <div class=\"container\">\n        <div class=\"text-center animate-on-scroll\">\n          <span class=\"section-label\">Our Work</span>\n          <h2 id=\"portfolio-heading\">Recent Projects</h2>\n          <p style=\"max-width:480px;margin:14px auto 0;\">A sample of tile installations we've completed for homeowners across the Sacramento area.</p>\n        </div>\n        <div class=\"portfolio-grid\">\n          <div class=\"portfolio-item\">\n            <img src=\"https://images.unsplash.com/photo-1552321554-5fefe8c9ef14?w=900&q=80\" alt=\"Custom large-format shower tile installation in Elk Grove Sacramento\" loading=\"lazy\" width=\"900\" height=\"506\" />\n            <div class=\"portfolio-item__overlay\"><span class=\"portfolio-item__label\">Custom Walk-In Shower \u2014 Elk Grove</span></div>\n          </div>\n          <div class=\"portfolio-item\">\n            <img src=\"https://images.unsplash.com/photo-1620626011761-996317702519?w=600&q=80\" alt=\"Herringbone kitchen backsplash tile installation Sacramento\" loading=\"lazy\" width=\"600\" height=\"450\" />\n            <div class=\"portfolio-item__overlay\"><span class=\"portfolio-item__label\">Herringbone Backsplash \u2014 Midtown</span></div>\n          </div>\n          <div class=\"portfolio-item\">\n            <img src=\"https://images.unsplash.com/photo-1584622650111-993a426fbf0a?w=600&q=80\" alt=\"Bathroom floor and wall tile remodel in Roseville Sacramento\" loading=\"lazy\" width=\"600\" height=\"450\" />\n            <div class=\"portfolio-item__overlay\"><span class=\"portfolio-item__label\">Full Bath Remodel \u2014 Roseville</span></div>\n          </div>\n          <div class=\"portfolio-item\">\n            <img src=\"https://images.unsplash.com/photo-1600566752355-35792bedcfea?w=600&q=80\" alt=\"Travertine floor tile installation Sacramento home\" loading=\"lazy\" width=\"600\" height=\"450\" />\n            <div class=\"portfolio-item__overlay\"><span class=\"portfolio-item__label\">Travertine Flooring \u2014 East Sacramento</span></div>\n          </div>\n          <div class=\"portfolio-item\">\n            <img src=\"https://images.unsplash.com/photo-1556909114-f6e7ad7d3136?w=600&q=80\" alt=\"Modern white subway tile shower installation Folsom\" loading=\"lazy\" width=\"600\" height=\"450\" />\n            <div class=\"portfolio-item__overlay\"><span class=\"portfolio-item__label\">Subway Tile Shower \u2014 Folsom</span></div>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <!-- ======= TESTIMONIALS ======= -->\n    <section class=\"section section--gray\" aria-labelledby=\"reviews-heading\">\n      <div class=\"container\">\n        <div class=\"text-center animate-on-scroll\">\n          <span class=\"section-label\">Client Reviews</span>\n          <h2 id=\"reviews-heading\">What Sacramento Homeowners Say</h2>\n        </div>\n        <div class=\"testimonials-grid\">\n          <div class=\"testimonial-card animate-on-scroll\">\n            <div class=\"testimonial-card__stars\">\n              <svg viewBox=\"0 0 24 24\" fill=\"currentColor\"><polygon points=\"12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2\"/></svg>\n              <svg viewBox=\"0 0 24 24\" fill=\"currentColor\"><polygon points=\"12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2\"/></svg>\n              <svg viewBox=\"0 0 24 24\" fill=\"currentColor\"><polygon points=\"12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2\"/></svg>\n              <svg viewBox=\"0 0 24 24\" fill=\"currentColor\"><polygon points=\"12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2\"/></svg>\n              <svg viewBox=\"0 0 24 24\" fill=\"currentColor\"><polygon points=\"12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2\"/></svg>\n            </div>\n            <blockquote>\"We had our master bathroom completely retiled and the results are stunning. Clean lines, zero lippage on the large-format tile. The team was in and out in 4 days, no mess left behind.\"</blockquote>\n            <div class=\"testimonial-card__author\">\n              <div class=\"testimonial-card__avatar\">JM</div>\n              <div>\n                <div class=\"testimonial-card__name\">Jessica M.</div>\n                <div class=\"testimonial-card__location\">Elk Grove, CA</div>\n              </div>\n            </div>\n          </div>\n          <div class=\"testimonial-card animate-on-scroll\">\n            <div class=\"testimonial-card__stars\">\n              <svg viewBox=\"0 0 24 24\" fill=\"currentColor\"><polygon points=\"12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2\"/></svg>\n              <svg viewBox=\"0 0 24 24\" fill=\"currentColor\"><polygon points=\"12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2\"/></svg>\n              <svg viewBox=\"0 0 24 24\" fill=\"currentColor\"><polygon points=\"12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2\"/></svg>\n              <svg viewBox=\"0 0 24 24\" fill=\"currentColor\"><polygon points=\"12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2\"/></svg>\n              <svg viewBox=\"0 0 24 24\" fill=\"currentColor\"><polygon points=\"12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2\"/></svg>\n            </div>\n            <blockquote>\"Got three quotes for my kitchen backsplash. Pro Tiling wasn't the cheapest but they were clearly the most knowledgeable. The finished product looks like it belongs in a magazine.\"</blockquote>\n            <div class=\"testimonial-card__author\">\n              <div class=\"testimonial-card__avatar\">DR</div>\n              <div>\n                <div class=\"testimonial-card__name\">David R.</div>\n                <div class=\"testimonial-card__location\">Roseville, CA</div>\n              </div>\n            </div>\n          </div>\n          <div class=\"testimonial-card animate-on-scroll\">\n            <div class=\"testimonial-card__stars\">\n              <svg viewBox=\"0 0 24 24\" fill=\"currentColor\"><polygon points=\"12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2\"/></svg>\n              <svg viewBox=\"0 0 24 24\" fill=\"currentColor\"><polygon points=\"12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2\"/></svg>\n              <svg viewBox=\"0 0 24 24\" fill=\"currentColor\"><polygon points=\"12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2\"/></svg>\n              <svg viewBox=\"0 0 24 24\" fill=\"currentColor\"><polygon points=\"12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2\"/></svg>\n              <svg viewBox=\"0 0 24 24\" fill=\"currentColor\"><polygon points=\"12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2\"/></svg>\n            </div>\n            <blockquote>\"Had a complex herringbone pattern in my entryway that two other contractors said they couldn't do. Pro Tiling came out, assessed it the same day, and knocked it out in two days. Exceptional.\"</blockquote>\n            <div class=\"testimonial-card__author\">\n              <div class=\"testimonial-card__avatar\">ST</div>\n              <div>\n                <div class=\"testimonial-card__name\">Sandra T.</div>\n                <div class=\"testimonial-card__location\">Folsom, CA</div>\n              </div>\n            </div>\n          </div>\n        </div>\n        <div class=\"trust-badges animate-on-scroll\">\n          <div class=\"trust-badge\">\n            <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z\"/></svg>\n            CA Licensed Contractor\n          </div>\n          <div class=\"trust-badge\">\n            <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><polyline points=\"9 11 12 14 22 4\"/><path d=\"M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11\"/></svg>\n            Fully Insured\n          </div>\n          <div class=\"trust-badge\">\n            <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><polygon points=\"12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2\"/></svg>\n            5-Star Google Rated\n          </div>\n          <div class=\"trust-badge\">\n            <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><circle cx=\"12\" cy=\"12\" r=\"10\"/><polyline points=\"12 6 12 12 16 14\"/></svg>\n            10+ Years Experience\n          </div>\n          <div class=\"trust-badge\">\n            <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2\"/><circle cx=\"9\" cy=\"7\" r=\"4\"/><path d=\"M23 21v-2a4 4 0 00-3-3.87\"/><path d=\"M16 3.13a4 4 0 010 7.75\"/></svg>\n            500+ Completed Projects\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <!-- ======= SERVICE AREAS ======= -->\n    <section class=\"section section--dark\" aria-labelledby=\"areas-heading\">\n      <div class=\"container text-center\">\n        <span class=\"section-label section-label--light\">Coverage Area</span>\n        <h2 id=\"areas-heading\" style=\"color:#fff;\">Serving Sacramento &amp; Surrounding Communities</h2>\n        <p class=\"lead lead--light\" style=\"max-width:520px;margin:14px auto 0;\">\n          Based in Sacramento, we regularly serve homeowners and contractors throughout the greater region.\n        </p>\n        <div class=\"areas-grid\" role=\"list\">\n          <div class=\"area-chip\" role=\"listitem\">Sacramento</div>\n          <div class=\"area-chip\" role=\"listitem\">Elk Grove</div>\n          <div class=\"area-chip\" role=\"listitem\">Roseville</div>\n          <div class=\"area-chip\" role=\"listitem\">Folsom</div>\n          <div class=\"area-chip\" role=\"listitem\">Natomas</div>\n          <div class=\"area-chip\" role=\"listitem\">Rancho Cordova</div>\n          <div class=\"area-chip\" role=\"listitem\">Citrus Heights</div>\n          <div class=\"area-chip\" role=\"listitem\">Rocklin</div>\n        </div>\n        <p style=\"margin-top:28px;font-size:0.875rem;color:rgba(255,255,255,0.45);\">Not sure if we cover your area? <a href=\"/contact\" style=\"color:var(--green);text-decoration:underline;\">Give us a call</a> \u2014 we're flexible.</p>\n      </div>\n    </section>\n\n    <!-- ======= FAQ ======= -->\n    <section class=\"section\" aria-labelledby=\"faq-heading\">\n      <div class=\"container\">\n        <div class=\"text-center animate-on-scroll\">\n          <span class=\"section-label\">Common Questions</span>\n          <h2 id=\"faq-heading\">Frequently Asked Questions</h2>\n        </div>\n        <div class=\"faq\" role=\"list\">\n          <div class=\"faq-item\" role=\"listitem\">\n            <button class=\"faq-item__question\" aria-expanded=\"false\">\n              How much does tile installation cost in Sacramento?\n              <span class=\"faq-item__icon\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><line x1=\"12\" y1=\"5\" x2=\"12\" y2=\"19\"/><line x1=\"5\" y1=\"12\" x2=\"19\" y2=\"12\"/></svg></span>\n            </button>\n            <div class=\"faq-item__answer\">\n              <p>Tile installation in Sacramento typically ranges from $8\u2013$25 per square foot installed, depending on tile type, layout complexity, and the surface prep required. Custom work with large-format tile, heated floors, or intricate patterns may be priced higher. We always provide a detailed written estimate before any work begins \u2014 no surprises.</p>\n            </div>\n          </div>\n          <div class=\"faq-item\" role=\"listitem\">\n            <button class=\"faq-item__question\" aria-expanded=\"false\">\n              How long does a bathroom tile remodel take?\n              <span class=\"faq-item__icon\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><line x1=\"12\" y1=\"5\" x2=\"12\" y2=\"19\"/><line x1=\"5\" y1=\"12\" x2=\"19\" y2=\"12\"/></svg></span>\n            </button>\n            <div class=\"faq-item__answer\">\n              <p>Most bathroom tile remodels take 3\u20137 business days from demolition to final grout seal, depending on scope. A simple floor swap is faster; a full shower + floor + wall renovation takes longer. We'll give you a realistic timeline before we start, and we stick to it.</p>\n            </div>\n          </div>\n          <div class=\"faq-item\" role=\"listitem\">\n            <button class=\"faq-item__question\" aria-expanded=\"false\">\n              Are you licensed and insured in California?\n              <span class=\"faq-item__icon\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><line x1=\"12\" y1=\"5\" x2=\"12\" y2=\"19\"/><line x1=\"5\" y1=\"12\" x2=\"19\" y2=\"12\"/></svg></span>\n            </button>\n            <div class=\"faq-item__answer\">\n              <p>Yes. Pro Tiling is a fully licensed California tile contractor. We carry general liability insurance and workers' compensation on every job. We're happy to share documentation before any project starts.</p>\n            </div>\n          </div>\n          <div class=\"faq-item\" role=\"listitem\">\n            <button class=\"faq-item__question\" aria-expanded=\"false\">\n              Do you provide tile, or do I need to supply my own?\n              <span class=\"faq-item__icon\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><line x1=\"12\" y1=\"5\" x2=\"12\" y2=\"19\"/><line x1=\"5\" y1=\"12\" x2=\"19\" y2=\"12\"/></svg></span>\n            </button>\n            <div class=\"faq-item__answer\">\n              <p>Both options work. We can source tile for you through our trade accounts \u2014 often at better pricing than retail \u2014 or we can install tile you've already purchased. We'll walk you through quantities, overage recommendations, and material selection during your estimate.</p>\n            </div>\n          </div>\n          <div class=\"faq-item\" role=\"listitem\">\n            <button class=\"faq-item__question\" aria-expanded=\"false\">\n              What tile types do you work with?\n              <span class=\"faq-item__icon\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><line x1=\"12\" y1=\"5\" x2=\"12\" y2=\"19\"/><line x1=\"5\" y1=\"12\" x2=\"19\" y2=\"12\"/></svg></span>\n            </button>\n            <div class=\"faq-item__answer\">\n              <p>We install porcelain, ceramic, natural stone (travertine, marble, slate), glass tile, mosaic, encaustic cement tile, and large-format slabs. If it's tile, we can set it.</p>\n            </div>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <!-- ======= LEAD FORM ======= -->\n    <section class=\"section section--gray\" aria-labelledby=\"quote-heading\">\n      <div class=\"container\">\n        <div class=\"text-center animate-on-scroll\" style=\"margin-bottom:40px;\">\n          <span class=\"section-label\">Get Started</span>\n          <h2 id=\"quote-heading\">Request a Free Estimate</h2>\n          <p style=\"max-width:440px;margin:12px auto 0;\">Tell us about your project and we'll get back to you within one business day.</p>\n        </div>\n        <div class=\"lead-form animate-on-scroll\">\n          <form novalidate>\n            <div class=\"form-grid\">\n              <div class=\"form-group\">\n                <label for=\"fname\">First Name</label>\n                <input type=\"text\" id=\"fname\" name=\"first_name\" placeholder=\"John\" required autocomplete=\"given-name\" />\n              </div>\n              <div class=\"form-group\">\n                <label for=\"lname\">Last Name</label>\n                <input type=\"text\" id=\"lname\" name=\"last_name\" placeholder=\"Smith\" required autocomplete=\"family-name\" />\n              </div>\n              <div class=\"form-group\">\n                <label for=\"phone\">Phone Number</label>\n                <input type=\"tel\" id=\"phone\" name=\"phone\" placeholder=\"(916) 555-0100\" required autocomplete=\"tel\" />\n              </div>\n              <div class=\"form-group\">\n                <label for=\"email\">Email Address</label>\n                <input type=\"email\" id=\"email\" name=\"email\" placeholder=\"john@email.com\" autocomplete=\"email\" />\n              </div>\n              <div class=\"form-group\">\n                <label for=\"service\">Service Needed</label>\n                <select id=\"service\" name=\"service\" required>\n                  <option value=\"\">Select a service...</option>\n                  <option>Tile Installation</option>\n                  <option>Bathroom Tile Remodel</option>\n                  <option>Shower Tile Installation</option>\n                  <option>Kitchen Backsplash</option>\n                  <option>Tile Flooring</option>\n                  <option>Custom Tile Work</option>\n                  <option>Not Sure \u2014 Need Advice</option>\n                </select>\n              </div>\n              <div class=\"form-group\">\n                <label for=\"city\">Your City</label>\n                <input type=\"text\" id=\"city\" name=\"city\" placeholder=\"Sacramento, Elk Grove...\" autocomplete=\"address-level2\" />\n              </div>\n              <div class=\"form-group form-group--full\">\n                <label for=\"message\">Project Details</label>\n                <textarea id=\"message\" name=\"message\" placeholder=\"Tell us about your project \u2014 room size, tile style, timeline, anything helpful...\" rows=\"4\"></textarea>\n              </div>\n            </div>\n            <div class=\"form-submit\">\n              <button type=\"submit\" class=\"btn btn--primary\">Send My Request</button>\n            </div>\n            <p class=\"form-note\">\n              <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" style=\"width:13px;height:13px;vertical-align:middle;display:inline;margin-right:4px;\"><path d=\"M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z\"/></svg>\n              No spam. We'll only use your info to respond to your request.\n            </p>\n          </form>\n        </div>\n      </div>\n    </section>\n\n    <!-- ======= CTA BAND ======= -->\n    <section class=\"cta-band\" aria-label=\"Call to action\">\n      <div class=\"container\">\n        <div class=\"cta-band__inner\">\n          <h2>Ready to transform your space? Let's <em>talk tile</em>.</h2>\n          <div class=\"cta-band__actions\">\n            <a href=\"tel:9165550100\" class=\"btn btn--primary\">\n              <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81 19.79 19.79 0 01.01 1.18 2 2 0 012 .01h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 14.92z\"/></svg>\n              (916) 555-0100\n            </a>\n            <a href=\"/contact\" class=\"btn btn--outline\">Get a Free Quote</a>\n          </div>\n        </div>\n      </div>\n    </section>";

---
import BaseLayout from "../layouts/BaseLayout.astro";
const pagePath = "/contact";
const title = "Contact Pro Tiling Sacramento | Free Tile Estimate";
const description = "";
const canonical = "";
const ogTitle = "";
const ogDescription = "";
const ogType = "";
const ogUrl = "";
const schemaScripts = [];
const contentHtml = "<section class=\"page-hero\">\n      <div class=\"container\">\n        <div class=\"page-hero__content\">\n          <nav class=\"page-hero__breadcrumb\" aria-label=\"Breadcrumb\">\n            <a href=\"/\">Home</a><span>\u203a</span><span>Contact</span>\n          </nav>\n          <h1>Get a Free Tile Estimate</h1>\n          <p>Tell us about your project and we'll get back to you within one business day. No obligation, no hard sell \u2014 just an honest assessment of your project and what it will take to do it right.</p>\n        </div>\n      </div>\n    </section>\n\n    <section class=\"section\">\n      <div class=\"container\">\n        <div class=\"contact-grid\">\n          <div class=\"contact-info animate-on-scroll\">\n            <span class=\"section-label\">Reach Us Directly</span>\n            <h2>We'd Love to Hear About Your Project</h2>\n            <p>Whether you're ready to start immediately or still in the planning stage, reach out. We'll help you think through the project, choose the right tile approach, and give you an honest number.</p>\n            <div class=\"contact-details\">\n              <div class=\"contact-detail\">\n                <div class=\"contact-detail__icon\">\n                  <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81 19.79 19.79 0 01.01 1.18 2 2 0 012 .01h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 14.92z\"/></svg>\n                </div>\n                <div>\n                  <div class=\"contact-detail__label\">Phone</div>\n                  <div class=\"contact-detail__value\"><a href=\"tel:9165550100\" style=\"color:inherit;\">(916) 555-0100</a></div>\n                </div>\n              </div>\n              <div class=\"contact-detail\">\n                <div class=\"contact-detail__icon\">\n                  <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z\"/><polyline points=\"22,6 12,13 2,6\"/></svg>\n                </div>\n                <div>\n                  <div class=\"contact-detail__label\">Email</div>\n                  <div class=\"contact-detail__value\"><a href=\"mailto:info@protiling.com\" style=\"color:inherit;\">info@protiling.com</a></div>\n                </div>\n              </div>\n              <div class=\"contact-detail\">\n                <div class=\"contact-detail__icon\">\n                  <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><circle cx=\"12\" cy=\"12\" r=\"10\"/><polyline points=\"12 6 12 12 16 14\"/></svg>\n                </div>\n                <div>\n                  <div class=\"contact-detail__label\">Business Hours</div>\n                  <div class=\"contact-detail__value\">Mon\u2013Fri: 7am\u20136pm</div>\n                  <div style=\"font-size:0.875rem;color:var(--mid-gray);margin-top:2px;\">Sat: 8am\u20132pm &nbsp;|&nbsp; Sun: Closed</div>\n                </div>\n              </div>\n              <div class=\"contact-detail\">\n                <div class=\"contact-detail__icon\">\n                  <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z\"/><circle cx=\"12\" cy=\"10\" r=\"3\"/></svg>\n                </div>\n                <div>\n                  <div class=\"contact-detail__label\">Service Area</div>\n                  <div class=\"contact-detail__value\">Greater Sacramento, CA</div>\n                  <div style=\"font-size:0.875rem;color:var(--mid-gray);margin-top:2px;\">Elk Grove \u00b7 Roseville \u00b7 Folsom \u00b7 Natomas \u00b7 Rancho Cordova \u00b7 Citrus Heights \u00b7 Rocklin</div>\n                </div>\n              </div>\n            </div>\n\n            <!-- Map placeholder \u2014 replace with actual Google Maps embed -->\n            <div class=\"map-placeholder\">\n              <iframe\n                title=\"Pro Tiling Sacramento location map\"\n                src=\"https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d199.83!2d-121.4944!3d38.5816!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x809ac672b28397f9%3A0x921f6aaa74197fdb!2sSacramento%2C%20CA!5e0!3m2!1sen!2sus!4v1234567890\"\n                loading=\"lazy\"\n                referrerpolicy=\"no-referrer-when-downgrade\"\n                aria-label=\"Map showing Pro Tiling service area in Sacramento, CA\">\n              </iframe>\n            </div>\n          </div>\n\n          <div class=\"animate-on-scroll\">\n            <div class=\"lead-form contact-form\">\n              <h3 style=\"font-family:var(--font-display);font-size:1.6rem;font-weight:400;margin-bottom:6px;\">Request a Free Estimate</h3>\n              <p style=\"font-size:0.875rem;margin-bottom:28px;\">We respond within one business day. Usually same day.</p>\n              <form novalidate>\n                <div class=\"form-grid\">\n                  <div class=\"form-group\">\n                    <label for=\"c-fname\">First Name</label>\n                    <input type=\"text\" id=\"c-fname\" name=\"first_name\" placeholder=\"John\" required autocomplete=\"given-name\" />\n                  </div>\n                  <div class=\"form-group\">\n                    <label for=\"c-lname\">Last Name</label>\n                    <input type=\"text\" id=\"c-lname\" name=\"last_name\" placeholder=\"Smith\" required autocomplete=\"family-name\" />\n                  </div>\n                  <div class=\"form-group\">\n                    <label for=\"c-phone\">Phone Number</label>\n                    <input type=\"tel\" id=\"c-phone\" name=\"phone\" placeholder=\"(916) 555-0100\" required autocomplete=\"tel\" />\n                  </div>\n                  <div class=\"form-group\">\n                    <label for=\"c-email\">Email Address</label>\n                    <input type=\"email\" id=\"c-email\" name=\"email\" placeholder=\"john@email.com\" autocomplete=\"email\" />\n                  </div>\n                  <div class=\"form-group\">\n                    <label for=\"c-service\">Service Needed</label>\n                    <select id=\"c-service\" name=\"service\" required>\n                      <option value=\"\">Select a service...</option>\n                      <option>Tile Installation</option>\n                      <option>Bathroom Tile Remodel</option>\n                      <option>Shower Tile Installation</option>\n                      <option>Kitchen Backsplash</option>\n                      <option>Tile Flooring</option>\n                      <option>Custom Tile Work</option>\n                      <option>Not Sure \u2014 Need Advice</option>\n                    </select>\n                  </div>\n                  <div class=\"form-group\">\n                    <label for=\"c-city\">Your City</label>\n                    <input type=\"text\" id=\"c-city\" name=\"city\" placeholder=\"Sacramento, Elk Grove...\" autocomplete=\"address-level2\" />\n                  </div>\n                  <div class=\"form-group\">\n                    <label for=\"c-timeline\">Timeline</label>\n                    <select id=\"c-timeline\" name=\"timeline\">\n                      <option value=\"\">When do you want to start?</option>\n                      <option>ASAP</option>\n                      <option>Within 1 month</option>\n                      <option>1\u20133 months</option>\n                      <option>Just planning ahead</option>\n                    </select>\n                  </div>\n                  <div class=\"form-group\">\n                    <label for=\"c-budget\">Approximate Budget</label>\n                    <select id=\"c-budget\" name=\"budget\">\n                      <option value=\"\">Select a range...</option>\n                      <option>Under $1,000</option>\n                      <option>$1,000\u2013$3,000</option>\n                      <option>$3,000\u2013$7,500</option>\n                      <option>$7,500\u2013$15,000</option>\n                      <option>$15,000+</option>\n                      <option>Not sure yet</option>\n                    </select>\n                  </div>\n                  <div class=\"form-group form-group--full\">\n                    <label for=\"c-message\">Project Details</label>\n                    <textarea id=\"c-message\" name=\"message\" placeholder=\"Tell us about your project \u2014 what room, approximate size, tile style if you know it, and anything else that would help us understand the scope...\" rows=\"5\"></textarea>\n                  </div>\n                </div>\n                <div class=\"form-submit\">\n                  <button type=\"submit\" class=\"btn btn--primary\">Send My Estimate Request</button>\n                </div>\n                <p class=\"form-note\">\n                  <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" style=\"width:13px;height:13px;vertical-align:middle;display:inline;margin-right:4px;\"><path d=\"M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z\"/></svg>\n                  We'll only contact you regarding your project. No spam, ever.\n                </p>\n              </form>\n            </div>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <!-- Trust strip -->\n    <section class=\"section--tight section--gray\">\n      <div class=\"container\">\n        <div class=\"trust-badges\" style=\"justify-content:center;\">\n          <div class=\"trust-badge\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z\"/></svg>CA Licensed Contractor</div>\n          <div class=\"trust-badge\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><polyline points=\"20 6 9 17 4 12\"/></svg>Fully Insured</div>\n          <div class=\"trust-badge\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><polygon points=\"12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2\"/></svg>5-Star Google Rated</div>\n          <div class=\"trust-badge\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><circle cx=\"12\" cy=\"12\" r=\"10\"/><polyline points=\"12 6 12 12 16 14\"/></svg>10+ Years Experience</div>\n          <div class=\"trust-badge\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z\"/></svg>Same-Day Response</div>\n        </div>\n      </div>\n    </section>";
---

<BaseLayout
  pagePath={pagePath}
  title={title}
  description={description}
  canonical={canonical}
  ogTitle={ogTitle}
  ogDescription={ogDescription}
  ogType={ogType}
  ogUrl={ogUrl}
  schemaScripts={schemaScripts}
>
  <Fragment set:html={contentHtml} />
</BaseLayout>
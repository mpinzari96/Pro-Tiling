---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";

interface Props {
  pagePath?: string;
  title?: string;
  description?: string;
  canonical?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogType?: string;
  ogUrl?: string;
  schemaScripts?: string[];
}

const {
  pagePath = "/",
  title = "Pro Tiling Sacramento",
  description = "Sacramento tile contractor for custom tile installation and remodels.",
  canonical = "",
  ogTitle = "",
  ogDescription = "",
  ogType = "website",
  ogUrl = "",
  schemaScripts = [],
} = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {canonical && <link rel="canonical" href={canonical} />}
    {ogTitle && <meta property="og:title" content={ogTitle} />}
    {ogDescription && <meta property="og:description" content={ogDescription} />}
    {ogType && <meta property="og:type" content={ogType} />}
    {ogUrl && <meta property="og:url" content={ogUrl} />}
    {schemaScripts.map((script) => <script type="application/ld+json" set:html={script} />)}
  </head>
  <body>
    <Header currentPath={pagePath} />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
    <script is:inline src="/scripts/main.js"></script>
  </body>
</html>
